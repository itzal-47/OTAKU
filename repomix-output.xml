        </div>
        <div className="p-5 space-y-4">
          <div>
            <label className="text-xs text-text3 font-medium mb-1.5 block">Nome</label>
            <input value={form.name} onChange={e => setForm({ ...form, name: e.target.value })} className="input w-full text-sm" />
