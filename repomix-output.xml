                >
                  <Lock size={16} />
                  Abrir Terminal
                </button>
              ) : (
                <button
                  onClick={() => setShowPasswordModal(true)}
                  className="btn btn-ghost flex items-center gap-2 border-amber/30 text-amber hover:bg-amber/10"
                >
                  <Lock size={16} />
                  Autenticar
                </button>
              )}
